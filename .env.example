# Copy this file to .env and update values before deployment.

# Core Django settings
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret

# Railway PostgreSQL connection string
# Example: postgresql://user:password@host:port/railway
DATABASE_URL=

# Add both Railway and custom domains when available
ALLOWED_HOSTS=your-service.up.railway.app,your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-service.up.railway.app,https://your-domain.com,https://www.your-domain.com

# HTTPS/security flags (recommended for production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional: auto-create or update a default admin account on deploy
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-password
